# Tribe Harbor Phone environment variables — NAMES ONLY, no real values here.
# Copy to .env.local for local dev. In production these come from Cloud Run
# env vars + Secret Manager (see docs/deploy.md). Never commit real values.

# --- Twilio identifiers (not secret, but account-specific) ---
# Console home page → Account Info
TWILIO_ACCOUNT_SID=
# Console → Account → API keys & tokens → Create API key (SK...)
TWILIO_API_KEY_SID=
# The Trifecta Benefits number in E.164, e.g. +15551234567
# Console → Phone Numbers → Manage → Active numbers
TWILIO_PHONE_NUMBER=
# Console → Voice → TwiML Apps (AP...)
TWILIO_TWIML_APP_SID=
# Console → Conversations → Services (IS...)
TWILIO_CONVERSATIONS_SERVICE_SID=

# --- Secrets (Secret Manager in production) ---
# Shown once when the API key is created
TWILIO_API_KEY_SECRET=
# Console home page → Account Info → Auth Token
TWILIO_AUTH_TOKEN=
# Generate: openssl rand -hex 32
SESSION_SECRET=
# Marie's login password
MARIE_PASSWORD=

# --- Optional ---
# Forward unanswered inbound calls here (E.164); else voicemail
VOICE_FALLBACK_NUMBER=
# Public URL of the deployed app. REQUIRED in production (webhook signature
# validation behind the Cloud Run proxy). Set after the first deploy.
APP_BASE_URL=
